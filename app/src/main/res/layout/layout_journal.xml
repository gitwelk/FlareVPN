<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/layout_journal"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:clickable="true"
    android:focusable="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/toolbar_journal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="56dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/btn_journal_back"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:padding="12dp"
            android:src="@drawable/ic_arrow_left"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:tint="@color/text_primary"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

        <TextView
            android:id="@+id/tv_journal_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/journal_title"
            android:textColor="@color/text_primary"
            android:textSize="18sp"
            android:fontFamily="@font/geologica_medium"
            app:fontFamily="@font/geologica_medium"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            android:ellipsize="end"
            android:maxLines="1"
            app:layout_constraintStart_toEndOf="@id/btn_journal_back"
            app:layout_constraintEnd_toStartOf="@id/btn_journal_clear"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

        <TextView
            android:id="@+id/btn_journal_clear"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:paddingHorizontal="16dp"
            android:gravity="center"
            android:text="@string/journal_clear"
            android:textColor="@color/accent"
            android:tag="accent_text"
            android:textSize="15sp"
            android:fontFamily="@font/geologica_medium"
            app:fontFamily="@font/geologica_medium"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_margin="16dp"
        android:background="@drawable/bg_journal_container"
        android:orientation="vertical"
        app:layout_constraintTop_toBottomOf="@id/toolbar_journal"
        app:layout_constraintBottom_toBottomOf="parent">

        <androidx.core.widget.NestedScrollView
            android:id="@+id/sv_journal"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:paddingBottom="16dp"
            android:clipToPadding="false">

            <TextView
                android:id="@+id/tv_journal_content"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="12dp"
                android:textColor="@color/text_primary"
                android:textSize="13sp"
                android:fontFamily="@font/geologica_regular"
                app:fontFamily="@font/geologica_regular"
                android:letterSpacing="0.02"
                android:lineSpacingExtra="4dp" />

        </androidx.core.widget.NestedScrollView>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
