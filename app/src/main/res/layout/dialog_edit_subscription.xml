<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/edit_sub_title"
        android:textColor="@color/text_primary"
        android:textSize="18sp"
        android:fontFamily="@font/geologica_medium"
            app:fontFamily="@font/geologica_medium"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/edit_sub_name_hint"
        android:textColor="@color/text_secondary"
        android:textSize="12sp"
        android:fontFamily="@font/geologica_regular"
            app:fontFamily="@font/geologica_regular"
        android:layout_marginBottom="8dp" />

    <EditText
        android:id="@+id/et_sub_name"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:tag="accent_bg"
        android:background="@drawable/bg_edit_text_field"
        android:hint="@string/edit_sub_name_hint"
        android:textColorHint="@color/text_secondary"
        android:textColor="@color/text_primary"
        android:paddingHorizontal="16dp"
        android:textSize="14sp"
        android:fontFamily="@font/geologica_regular"
            app:fontFamily="@font/geologica_regular"
        android:layout_marginBottom="16dp"
        android:inputType="text"
        android:maxLines="1" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/edit_sub_url_hint"
        android:textColor="@color/text_secondary"
        android:textSize="12sp"
        android:fontFamily="@font/geologica_regular"
            app:fontFamily="@font/geologica_regular"
        android:layout_marginBottom="8dp" />

    <EditText
        android:id="@+id/et_sub_url"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:tag="accent_bg"
        android:background="@drawable/bg_edit_text_field"
        android:hint="@string/edit_sub_url_hint"
        android:textColorHint="@color/text_secondary"
        android:textColor="@color/text_primary"
        android:paddingHorizontal="16dp"
        android:textSize="14sp"
        android:fontFamily="@font/geologica_regular"
            app:fontFamily="@font/geologica_regular"
        android:layout_marginBottom="16dp"
        android:inputType="textUri"
        android:maxLines="1" />

    <LinearLayout
        android:id="@+id/layout_support"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone"
        android:layout_marginBottom="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_support"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:fontFamily="@font/geologica_regular"
            app:fontFamily="@font/geologica_regular"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minWidth="160dp"
            android:orientation="vertical">

            <LinearLayout
                android:id="@+id/layout_support_web"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingVertical="10dp"
                android:paddingHorizontal="14dp"
                android:tag="accent_bg"
                android:background="@drawable/bg_edit_text_field"
                android:layout_marginBottom="12dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_chrome"
                    android:tint="@color/text_primary" />

                <TextView
                    android:id="@+id/tv_support_web_link"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:textColor="@color/text_primary"
                    android:textSize="13sp"
                    android:fontFamily="@font/geologica_regular"
                    android:singleLine="true"
                    android:ellipsize="end" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/layout_support_tg"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingVertical="10dp"
                android:paddingHorizontal="14dp"
                android:tag="accent_bg"
                android:background="@drawable/bg_edit_text_field"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_telegram"
                    android:tint="@color/text_primary" />

                <TextView
                    android:id="@+id/tv_support_tg_link"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:textColor="@color/text_primary"
                    android:textSize="13sp"
                    android:fontFamily="@font/geologica_regular"
                    android:singleLine="true"
                    android:ellipsize="end" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/btn_cancel"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="@string/btn_cancel"
            android:textColor="@color/text_secondary"
            android:gravity="center"
            android:fontFamily="@font/geologica_medium"
            app:fontFamily="@font/geologica_medium"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true" />

        <View
            android:layout_width="20dp"
            android:layout_height="match_parent" />

        <TextView
            android:id="@+id/btn_save"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="@string/btn_save"
            android:textColor="@color/accent"
            android:tag="accent_text"
            android:gravity="center"
            android:fontFamily="@font/geologica_medium"
            app:fontFamily="@font/geologica_medium"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true" />
    </LinearLayout>

</LinearLayout>
