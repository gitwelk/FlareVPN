<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:id="@+id/tv_dialog_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/dialog_apps_title"
        android:textColor="@color/text_primary"
        android:textSize="18sp"
        android:fontFamily="@font/geologica_medium"
            app:fontFamily="@font/geologica_medium"
        android:layout_marginBottom="12dp" />

    <FrameLayout
        android:id="@+id/tab_container"
        android:layout_width="200dp"
        android:layout_height="40dp"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="12dp"
        android:background="@drawable/bg_bottom_nav">

        <flare.client.app.ui.widget.LiquidPillView
            android:id="@+id/tab_indicator"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:alpha="0"
            android:clickable="false"
            android:focusable="false" />

        <LinearLayout
            android:id="@+id/il_tab_icons"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:clickable="false"
            android:focusable="false">

            <ImageView
                android:id="@+id/tab_apps"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:padding="8dp"
                android:src="@drawable/ic_apps"
                app:tint="@color/text_primary"
                android:clickable="false"
                android:focusable="false" />

            <ImageView
                android:id="@+id/tab_sites"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:padding="8dp"
                android:src="@drawable/ic_website"
                app:tint="@color/text_secondary"
                android:clickable="false"
                android:focusable="false" />
        </LinearLayout>

    </FrameLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="240dp"
        android:layout_marginBottom="8dp">

        <LinearLayout
            android:id="@+id/layout_apps"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <EditText
                android:id="@+id/et_search_apps"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/bg_glass_input"
                android:hint="@string/search_apps_hint"
                android:textColorHint="@color/text_secondary"
                android:textColor="@color/text_primary"
                android:paddingHorizontal="12dp"
                android:textSize="14sp"
                android:fontFamily="@font/geologica_regular"
            app:fontFamily="@font/geologica_regular"
                android:layout_marginBottom="8dp"
                android:inputType="text"
                android:maxLines="1" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_apps"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/layout_sites"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:visibility="gone">

            <EditText
                android:id="@+id/et_sites"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_glass_input"
                android:hint="@string/sites_hint"
                android:textColorHint="@color/text_secondary"
                android:textColor="@color/text_primary"
                android:padding="12dp"
                android:gravity="top|start"
                android:textSize="14sp"
                android:fontFamily="@font/geologica_regular"
            app:fontFamily="@font/geologica_regular"
                android:inputType="textMultiLine" />
        </LinearLayout>
    </FrameLayout>

    <LinearLayout
        android:id="@+id/btn_mode_selection"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/bg_glass_input"
        android:paddingHorizontal="12dp"
        android:clickable="true"
        android:focusable="true"
        android:layout_marginBottom="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_mode"
            android:textColor="@color/text_primary"
            android:textSize="16sp"
            android:maxLines="1"
            android:ellipsize="end"
            android:fontFamily="@font/geologica_medium"
            app:fontFamily="@font/geologica_medium" />

        <TextView
            android:id="@+id/tv_mode_value"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="end"
            android:text="@string/split_mode_blacklist"
            android:textColor="@color/accent"
            android:tag="accent_text"
            android:textSize="16sp"
            android:maxLines="1"
            android:ellipsize="end"
            android:layout_marginStart="8dp"
            android:fontFamily="@font/geologica_medium"
            app:fontFamily="@font/geologica_medium" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/btn_cancel_apps"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="@string/btn_cancel"
            android:textColor="@color/text_secondary"
            android:gravity="center"
            android:fontFamily="@font/geologica_medium"
            app:fontFamily="@font/geologica_medium"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true" />

        <View
            android:layout_width="20dp"
            android:layout_height="match_parent" />

        <TextView
            android:id="@+id/btn_save_apps"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="@string/btn_save"
            android:textColor="@color/accent"
            android:tag="accent_text"
            android:gravity="center"
            android:fontFamily="@font/geologica_medium"
            app:fontFamily="@font/geologica_medium"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true" />
    </LinearLayout>

</LinearLayout>
