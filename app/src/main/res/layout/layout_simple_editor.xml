<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:clickable="true"
    android:focusable="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/toolbar_simple"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="56dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/btn_simple_back"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:padding="12dp"
            android:src="@drawable/ic_arrow_left"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:tint="@color/text_primary"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

        <TextView
            android:id="@+id/tv_simple_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/simple_editor_title"
            android:textColor="@color/text_primary"
            android:textSize="18sp"
            android:fontFamily="@font/geologica_medium"
            app:fontFamily="@font/geologica_medium"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            android:ellipsize="end"
            android:maxLines="1"
            app:layout_constraintStart_toEndOf="@id/btn_simple_back"
            app:layout_constraintEnd_toStartOf="@id/btn_simple_save"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

        <ImageView
            android:id="@+id/btn_simple_save"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:padding="12dp"
            android:src="@drawable/ic_check"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:tint="@color/accent"
            android:tag="accent_tint"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/toolbar_simple"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/simple_editor_basic"
                android:textColor="@color/accent"
                android:tag="accent_text"
                android:textSize="14sp"
                android:fontFamily="@font/geologica_medium"
            app:fontFamily="@font/geologica_medium"
                android:layout_marginBottom="12dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_grouped_all">
                
                
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="12dp"
                    android:gravity="center_vertical">
                    <TextView
                        android:layout_width="120dp"
                        android:layout_height="wrap_content"
                        android:text="@string/simple_editor_tag"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:fontFamily="@font/geologica_regular"
            app:fontFamily="@font/geologica_regular" />
                    <EditText
                        android:id="@+id/et_simple_tag"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@null"
                        android:textColor="@color/text_secondary"
                        android:textSize="14sp"
                        android:fontFamily="@font/geologica_regular"
            app:fontFamily="@font/geologica_regular"
                        android:inputType="text"
                        android:maxLines="1"
                        android:gravity="end" />
                </LinearLayout>
                
                <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="#33FFFFFF" android:layout_marginStart="12dp" />
                
                
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="12dp"
                    android:gravity="center_vertical">
                    <TextView
                        android:layout_width="120dp"
                        android:layout_height="wrap_content"
                        android:text="@string/simple_editor_server"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:fontFamily="@font/geologica_regular"
            app:fontFamily="@font/geologica_regular" />
                    <EditText
                        android:id="@+id/et_simple_server"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@null"
                        android:textColor="@color/text_secondary"
                        android:textSize="14sp"
                        android:fontFamily="@font/geologica_regular"
            app:fontFamily="@font/geologica_regular"
                        android:inputType="textUri"
                        android:maxLines="1"
                        android:gravity="end" />
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="#33FFFFFF" android:layout_marginStart="12dp" />
                
                
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="12dp"
                    android:gravity="center_vertical">
                    <TextView
                        android:layout_width="120dp"
                        android:layout_height="wrap_content"
                        android:text="@string/simple_editor_port"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:fontFamily="@font/geologica_regular"
            app:fontFamily="@font/geologica_regular" />
                    <EditText
                        android:id="@+id/et_simple_port"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@null"
                        android:textColor="@color/text_secondary"
                        android:textSize="14sp"
                        android:fontFamily="@font/geologica_regular"
            app:fontFamily="@font/geologica_regular"
                        android:inputType="number"
                        android:maxLines="1"
                        android:gravity="end" />
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="#33FFFFFF" android:layout_marginStart="12dp" />

                
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="12dp"
                    android:gravity="center_vertical">
                    <TextView
                        android:id="@+id/tv_simple_uuid_label"
                        android:layout_width="120dp"
                        android:layout_height="wrap_content"
                        android:text="@string/simple_editor_uuid_pwd"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:fontFamily="@font/geologica_regular"
            app:fontFamily="@font/geologica_regular" />
                    <EditText
                        android:id="@+id/et_simple_uuid"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@null"
                        android:textColor="@color/text_secondary"
                        android:textSize="14sp"
                        android:fontFamily="@font/geologica_regular"
            app:fontFamily="@font/geologica_regular"
                        android:inputType="textVisiblePassword"
                        android:maxLines="1"
                        android:gravity="end" />
                </LinearLayout>

                <View android:id="@+id/view_flow_divider" android:layout_width="match_parent" android:layout_height="0.5dp" android:background="#33FFFFFF" android:layout_marginStart="12dp" />

                
                <LinearLayout
                    android:id="@+id/layout_simple_flow"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="12dp"
                    android:gravity="center_vertical"
                    android:background="?attr/selectableItemBackground">
                    <TextView
                        android:layout_width="120dp"
                        android:layout_height="wrap_content"
                        android:text="@string/simple_editor_flow"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:fontFamily="@font/geologica_regular"
            app:fontFamily="@font/geologica_regular" />
                    <TextView
                        android:id="@+id/tv_simple_flow"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@null"
                        android:textColor="@color/text_secondary"
                        android:textSize="14sp"
                        android:fontFamily="@font/geologica_regular"
            app:fontFamily="@font/geologica_regular"
                        android:gravity="end" />
                </LinearLayout>

                <View android:id="@+id/view_method_divider" android:layout_width="match_parent" android:layout_height="0.5dp" android:background="#33FFFFFF" android:layout_marginStart="12dp" android:visibility="gone" />

                
                <LinearLayout
                    android:id="@+id/layout_simple_method"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="12dp"
                    android:gravity="center_vertical"
                    android:visibility="gone"
                    android:background="?attr/selectableItemBackground">
                    <TextView
                        android:layout_width="140dp"
                        android:layout_height="wrap_content"
                        android:text="@string/simple_editor_method"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:fontFamily="@font/geologica_regular"
            app:fontFamily="@font/geologica_regular" />
                    <TextView
                        android:id="@+id/tv_simple_method"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@null"
                        android:textColor="@color/text_secondary"
                        android:textSize="14sp"
                        android:fontFamily="@font/geologica_regular"
            app:fontFamily="@font/geologica_regular"
                        android:gravity="end" />
                </LinearLayout>

            </LinearLayout>

            
            <LinearLayout
                android:id="@+id/layout_tls_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="24dp">
                
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/simple_editor_tls"
                    android:textColor="@color/accent"
                    android:tag="accent_text"
                    android:textSize="14sp"
                    android:fontFamily="@font/geologica_medium"
            app:fontFamily="@font/geologica_medium"
                    android:layout_marginBottom="12dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/bg_grouped_all">
                    
                    
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="12dp"
                        android:gravity="center_vertical">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/simple_editor_enable_tls"
                            android:textColor="@color/text_primary"
                            android:textSize="14sp"
                            android:fontFamily="@font/geologica_regular"
            app:fontFamily="@font/geologica_regular" />
                        <flare.client.app.ui.widget.GlassyMaterialSwitch
                            android:id="@+id/sw_simple_tls"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            style="@style/Widget.Flare.MaterialSwitch" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/layout_tls_inner"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="#33FFFFFF" android:layout_marginStart="12dp" />
                        
                        
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:padding="12dp"
                            android:gravity="center_vertical">
                            <TextView
                                android:layout_width="120dp"
                                android:layout_height="wrap_content"
                                android:text="@string/simple_editor_sni"
                                android:textColor="@color/text_primary"
                                android:textSize="14sp"
                                android:fontFamily="@font/geologica_regular"
            app:fontFamily="@font/geologica_regular" />
                            <EditText
                                android:id="@+id/et_simple_sni"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:background="@null"
                                android:textColor="@color/text_secondary"
                                android:textSize="14sp"
                                android:fontFamily="@font/geologica_regular"
            app:fontFamily="@font/geologica_regular"
                                android:inputType="textUri"
                                android:maxLines="1"
                                android:gravity="end" />
                        </LinearLayout>

                        <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="#33FFFFFF" android:layout_marginStart="12dp" />
                        
                        
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:padding="12dp"
                            android:gravity="center_vertical">
                            <TextView
                                android:layout_width="120dp"
                                android:layout_height="wrap_content"
                                android:text="@string/simple_editor_alpn"
                                android:textColor="@color/text_primary"
                                android:textSize="14sp"
                                android:fontFamily="@font/geologica_regular"
            app:fontFamily="@font/geologica_regular" />
                            <EditText
                                android:id="@+id/et_simple_alpn"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:background="@null"
                                android:textColor="@color/text_secondary"
                                android:textSize="14sp"
                                android:fontFamily="@font/geologica_regular"
            app:fontFamily="@font/geologica_regular"
                                android:inputType="text"
                                android:maxLines="1"
                                android:gravity="end"
                                android:hint="h2,http/1.1"
                                android:textColorHint="#aaB0BDD1" />
                        </LinearLayout>

                        <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="#33FFFFFF" android:layout_marginStart="12dp" />

                        
                        <LinearLayout
                            android:id="@+id/layout_simple_fingerprint"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:padding="12dp"
                            android:gravity="center_vertical"
                            android:background="?attr/selectableItemBackground">
                            <TextView
                                android:layout_width="120dp"
                                android:layout_height="wrap_content"
                                android:text="@string/simple_editor_fingerprint"
                                android:textColor="@color/text_primary"
                                android:textSize="14sp"
                                android:fontFamily="@font/geologica_regular"
            app:fontFamily="@font/geologica_regular" />
                            <TextView
                                android:id="@+id/tv_simple_fingerprint"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:background="@null"
                                android:textColor="@color/text_secondary"
                                android:textSize="14sp"
                                android:fontFamily="@font/geologica_regular"
            app:fontFamily="@font/geologica_regular"
                                android:gravity="end" />
                        </LinearLayout>

                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            
            <LinearLayout
                android:id="@+id/layout_reality_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="24dp">
                
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/simple_editor_reality"
                    android:textColor="@color/accent"
                    android:tag="accent_text"
                    android:textSize="14sp"
                    android:fontFamily="@font/geologica_medium"
            app:fontFamily="@font/geologica_medium"
                    android:layout_marginBottom="12dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/bg_grouped_all">
                    
                    
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="12dp"
                        android:gravity="center_vertical">
                        <TextView
                            android:layout_width="120dp"
                            android:layout_height="wrap_content"
                            android:text="@string/simple_editor_pbk"
                            android:textColor="@color/text_primary"
                            android:textSize="14sp"
                            android:fontFamily="@font/geologica_regular"
            app:fontFamily="@font/geologica_regular" />
                        <EditText
                            android:id="@+id/et_simple_pbk"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:background="@null"
                            android:textColor="@color/text_secondary"
                            android:textSize="14sp"
                            android:fontFamily="@font/geologica_regular"
            app:fontFamily="@font/geologica_regular"
                            android:inputType="text"
                            android:maxLines="1"
                            android:gravity="end" />
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="#33FFFFFF" android:layout_marginStart="12dp" />

                    
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="12dp"
                        android:gravity="center_vertical">
                        <TextView
                            android:layout_width="120dp"
                            android:layout_height="wrap_content"
                            android:text="@string/simple_editor_sid"
                            android:textColor="@color/text_primary"
                            android:textSize="14sp"
                            android:fontFamily="@font/geologica_regular"
            app:fontFamily="@font/geologica_regular" />
                        <EditText
                            android:id="@+id/et_simple_sid"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:background="@null"
                            android:textColor="@color/text_secondary"
                            android:textSize="14sp"
                            android:fontFamily="@font/geologica_regular"
            app:fontFamily="@font/geologica_regular"
                            android:inputType="text"
                            android:maxLines="1"
                            android:gravity="end" />
                    </LinearLayout>

                </LinearLayout>
            </LinearLayout>
            
            <View android:layout_width="match_parent" android:layout_height="48dp" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
