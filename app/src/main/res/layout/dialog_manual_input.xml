<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/manual_input_title"
        android:textColor="@color/text_primary"
        android:textSize="18sp"
        android:fontFamily="@font/geologica_medium"
        app:fontFamily="@font/geologica_medium"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/label_credentials"
        android:textColor="@color/text_secondary"
        android:textSize="12sp"
        android:fontFamily="@font/geologica_regular"
        app:fontFamily="@font/geologica_regular"
        android:layout_marginBottom="8dp" />

    <EditText
        android:id="@+id/et_input"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="48dp"
        android:tag="accent_bg"
        android:background="@drawable/bg_edit_text_field"
        android:hint="@string/manual_input_hint"
        android:textColorHint="@color/text_secondary"
        android:textColor="@color/text_primary"
        android:paddingHorizontal="16dp"
        android:paddingVertical="12dp"
        android:textSize="14sp"
        android:fontFamily="@font/geologica_regular"
        app:fontFamily="@font/geologica_regular"
        android:layout_marginBottom="16dp"
        android:inputType="textMultiLine"
        android:gravity="top"
        android:maxLines="5" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/btn_cancel"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="@string/btn_cancel"
            android:textColor="@color/text_secondary"
            android:gravity="center"
            android:fontFamily="@font/geologica_medium"
            app:fontFamily="@font/geologica_medium"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true" />

        <View
            android:layout_width="20dp"
            android:layout_height="match_parent" />

        <TextView
            android:id="@+id/btn_add"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="@string/btn_add"
            android:textColor="@color/accent"
            android:tag="accent_text"
            android:gravity="center"
            android:fontFamily="@font/geologica_medium"
            app:fontFamily="@font/geologica_medium"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true" />
    </LinearLayout>

</LinearLayout>
