<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/layout_settings_base"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:visibility="gone"
    android:fillViewport="true"
    android:paddingBottom="160dp"
    android:clipToPadding="false">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="2dp"
        android:paddingHorizontal="20dp"
        android:paddingBottom="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="24dp">

            <ImageView
                android:id="@+id/btn_base_back"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:padding="8dp"
                android:src="@drawable/ic_arrow_left"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:tint="@color/text_primary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/settings_basic_title"
                android:textColor="@color/text_primary"
                android:textSize="22sp"
                android:fontFamily="@font/geologica_medium"
            app:fontFamily="@font/geologica_medium"
                android:layout_marginStart="8dp" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings_label_split_tunneling"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:fontFamily="@font/geologica_medium"
            app:fontFamily="@font/geologica_medium"
            android:layout_marginBottom="12dp"
            android:layout_marginStart="4dp" />

        <LinearLayout
            android:id="@+id/block_split_tunneling"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:id="@+id/btn_toggle_split_tunneling"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_grouped_all"
                android:paddingHorizontal="16dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/settings_label_split_tunneling"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"
                    android:fontFamily="@font/geologica_regular"
            app:fontFamily="@font/geologica_regular" />

                <flare.client.app.ui.widget.GlassyMaterialSwitch
                    android:id="@+id/sw_split_tunneling"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    style="@style/Widget.Flare.MaterialSwitch" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/layout_split_tunneling_sub"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                android:background="@drawable/bg_grouped_bottom">

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginStart="16dp"
                    android:background="@color/divider_color" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/tv_split_tunneling_desc"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/desc_select_apps"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:fontFamily="@font/geologica_regular"
            app:fontFamily="@font/geologica_regular"
                        android:layout_marginBottom="16dp"
                        android:alpha="0.7" />

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <androidx.appcompat.widget.AppCompatButton
                            android:id="@+id/btn_change_apps"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:background="@drawable/bg_button_accent"
                            android:text="@string/settings_btn_change"
                            android:textColor="@color/text_primary"
                            android:textSize="16sp"
                            android:fontFamily="@font/geologica_medium"
            app:fontFamily="@font/geologica_medium"
                            android:textAllCaps="false" />

                        <ProgressBar
                            android:id="@+id/pb_change_apps_loading"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_gravity="center"
                            android:visibility="gone"
                            android:indeterminateTint="@color/white" />
                    </FrameLayout>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>



        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings_header_autostart"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:fontFamily="@font/geologica_medium"
            app:fontFamily="@font/geologica_medium"
            android:layout_marginBottom="12dp"
            android:layout_marginStart="4dp" />

        <LinearLayout
            android:id="@+id/block_autostart"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:id="@+id/btn_toggle_autostart"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:orientation="vertical"
                android:background="@drawable/bg_grouped_all"
                android:paddingHorizontal="16dp"
                android:gravity="center_vertical">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/settings_label_autostart"
                            android:textColor="@color/text_primary"
                            android:textSize="16sp"
                            android:fontFamily="@font/geologica_regular"
            app:fontFamily="@font/geologica_regular" />

                    </LinearLayout>

                    <flare.client.app.ui.widget.GlassyMaterialSwitch
                        android:id="@+id/sw_autostart"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        style="@style/Widget.Flare.MaterialSwitch" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings_header_notifications"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:fontFamily="@font/geologica_medium"
            app:fontFamily="@font/geologica_medium"
            android:layout_marginBottom="12dp"
            android:layout_marginStart="4dp" />

        <LinearLayout
            android:id="@+id/block_notifications"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:id="@+id/btn_toggle_notifications"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_grouped_top"
                android:paddingHorizontal="16dp"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/settings_label_status"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"
                    android:fontFamily="@font/geologica_regular"
            app:fontFamily="@font/geologica_regular" />

                <flare.client.app.ui.widget.GlassyMaterialSwitch
                    android:id="@+id/sw_notifications"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    style="@style/Widget.Flare.MaterialSwitch" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginStart="16dp"
                android:background="@color/divider_color" />

            <LinearLayout
                android:id="@+id/btn_toggle_best_profile_notif"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_grouped_bottom"
                android:paddingHorizontal="16dp"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/settings_label_best_profile_notif"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"
                    android:fontFamily="@font/geologica_regular"
            app:fontFamily="@font/geologica_regular" />

                <flare.client.app.ui.widget.GlassyMaterialSwitch
                    android:id="@+id/sw_best_profile_notif"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    style="@style/Widget.Flare.MaterialSwitch" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings_header_hwid"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:fontFamily="@font/geologica_medium"
            app:fontFamily="@font/geologica_medium"
            android:layout_marginBottom="12dp"
            android:layout_marginStart="4dp" />

        <LinearLayout
            android:id="@+id/block_hwid"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:id="@+id/btn_toggle_hwid"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_grouped_all"
                android:paddingHorizontal="16dp"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:id="@+id/tv_hwid_label"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/settings_label_send_hwid"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"
                    android:fontFamily="@font/geologica_regular"
                    app:fontFamily="@font/geologica_regular" />

                <flare.client.app.ui.widget.GlassyMaterialSwitch
                    android:id="@+id/sw_hwid"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    style="@style/Widget.Flare.MaterialSwitch" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:id="@+id/tv_hwid_desc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/settings_desc_hwid"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:fontFamily="@font/geologica_regular"
            app:fontFamily="@font/geologica_regular"
            android:layout_marginBottom="24dp"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp"
            android:alpha="0.8"
            android:visibility="gone" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings_header_logging"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:fontFamily="@font/geologica_medium"
            app:fontFamily="@font/geologica_medium"
            android:layout_marginBottom="12dp"
            android:layout_marginStart="4dp" />

        <LinearLayout
            android:id="@+id/block_logging"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:id="@+id/btn_toggle_core_log"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_grouped_all"
                android:paddingHorizontal="16dp"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:id="@+id/tv_core_log_label"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/settings_label_core_log"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"
                    android:fontFamily="@font/geologica_regular"
                    app:fontFamily="@font/geologica_regular" />

                <flare.client.app.ui.widget.GlassyMaterialSwitch
                    android:id="@+id/sw_core_log"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    style="@style/Widget.Flare.MaterialSwitch" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/layout_core_log_sub"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginStart="16dp"
                    android:background="@color/divider_color" />

                <LinearLayout
                    android:id="@+id/btn_core_log_level"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_grouped_middle"
                    android:paddingHorizontal="16dp"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/settings_label_core_log_level"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp"
                        android:fontFamily="@font/geologica_regular"
                        app:fontFamily="@font/geologica_regular" />

                    <TextView
                        android:id="@+id/tv_core_log_level_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="warn"
                        android:textColor="@color/accent"
                        android:tag="accent_text"
                        android:textSize="16sp"
                        android:fontFamily="@font/geologica_medium"
                        app:fontFamily="@font/geologica_medium" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginStart="16dp"
                    android:background="@color/divider_color" />

                <LinearLayout
                    android:id="@+id/btn_view_journal"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_grouped_bottom"
                    android:paddingHorizontal="16dp"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/settings_btn_journal"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp"
                        android:fontFamily="@font/geologica_regular"
                        app:fontFamily="@font/geologica_regular" />

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_arrow_left"
                        android:rotation="180"
                        app:tint="@color/text_secondary" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:id="@+id/tv_logging_desc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/settings_desc_logging"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:fontFamily="@font/geologica_regular"
            app:fontFamily="@font/geologica_regular"
            android:layout_marginBottom="24dp"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp"
            android:alpha="0.8"
            android:visibility="gone" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings_header_best_profile"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:fontFamily="@font/geologica_medium"
            app:fontFamily="@font/geologica_medium"
            android:layout_marginBottom="8dp"
            android:layout_marginStart="4dp" />

        <LinearLayout
            android:id="@+id/block_best_profile"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:id="@+id/btn_toggle_best_profile"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_grouped_all"
                android:paddingHorizontal="16dp">

                <TextView
                    android:id="@+id/tv_best_profile_label"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/settings_label_best_profile"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"
                    android:fontFamily="@font/geologica_regular"
            app:fontFamily="@font/geologica_regular" />

                <flare.client.app.ui.widget.GlassyMaterialSwitch
                    android:id="@+id/sw_best_profile"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    style="@style/Widget.Flare.MaterialSwitch" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/layout_best_profile_sub"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginStart="16dp"
                    android:background="@color/divider_color" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_grouped_middle"
                    android:paddingHorizontal="16dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/settings_label_best_profile_interval"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp"
                        android:fontFamily="@font/geologica_regular"
            app:fontFamily="@font/geologica_regular" />

                    <EditText
                        android:id="@+id/et_best_profile_interval"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:minWidth="50dp"
                        android:background="@null"
                        android:gravity="end"
                        android:hint="@string/settings_hint_best_profile_interval"
                        android:textColorHint="@color/text_secondary"
                        android:textColor="@color/accent"
                        android:tag="accent_text"
                        android:textSize="16sp"
                        android:fontFamily="@font/geologica_medium"
            app:fontFamily="@font/geologica_medium"
                        android:inputType="number"
                        android:imeOptions="actionDone" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/label_seconds_short"
                        android:textColor="@color/accent"
                        android:tag="accent_text"
                        android:textSize="16sp"
                        android:fontFamily="@font/geologica_medium"
            app:fontFamily="@font/geologica_medium"
                        android:layout_marginStart="2dp" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginStart="16dp"
                    android:background="@color/divider_color" />

                <LinearLayout
                    android:id="@+id/btn_best_profile_only_connected"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_grouped_bottom"
                    android:paddingHorizontal="16dp"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/settings_label_best_profile_only_connected"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp"
                        android:fontFamily="@font/geologica_regular"
            app:fontFamily="@font/geologica_regular" />

                    <TextView
                        android:id="@+id/tv_best_profile_only_connected_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/option_yes"
                        android:textColor="@color/accent"
                        android:tag="accent_text"
                        android:textSize="16sp"
                        android:fontFamily="@font/geologica_medium"
            app:fontFamily="@font/geologica_medium" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:id="@+id/tv_best_profile_desc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/settings_desc_best_profile"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:fontFamily="@font/geologica_regular"
            app:fontFamily="@font/geologica_regular"
            android:layout_marginBottom="8dp"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp"
            android:alpha="0.8"
            android:visibility="gone" />

        <LinearLayout
            android:id="@+id/block_adaptive_tunnel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:id="@+id/btn_toggle_adaptive_tunnel"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_grouped_all"
                android:paddingHorizontal="16dp"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:id="@+id/tv_adaptive_tunnel_label"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/settings_label_adaptive_tunnel"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"
                    android:fontFamily="@font/geologica_regular"
                    app:fontFamily="@font/geologica_regular" />

                <flare.client.app.ui.widget.GlassyMaterialSwitch
                    android:id="@+id/sw_adaptive_tunnel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    style="@style/Widget.Flare.MaterialSwitch" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:id="@+id/tv_adaptive_tunnel_desc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/settings_desc_adaptive_tunnel"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:fontFamily="@font/geologica_regular"
            app:fontFamily="@font/geologica_regular"
            android:layout_marginBottom="24dp"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp"
            android:alpha="0.8"
            android:visibility="gone" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings_header_updates"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:fontFamily="@font/geologica_medium"
            app:fontFamily="@font/geologica_medium"
            android:layout_marginBottom="8dp"
            android:layout_marginStart="4dp" />

        <LinearLayout
            android:id="@+id/block_update_check"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:id="@+id/btn_toggle_update_check"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_grouped_all"
                android:paddingHorizontal="16dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/settings_label_update_check"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"
                    android:fontFamily="@font/geologica_regular"
            app:fontFamily="@font/geologica_regular" />

                <flare.client.app.ui.widget.GlassyMaterialSwitch
                    android:id="@+id/sw_update_check"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    style="@style/Widget.Flare.MaterialSwitch" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/layout_update_check_sub"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginStart="16dp"
                    android:background="@color/divider_color" />

                <LinearLayout
                    android:id="@+id/btn_update_frequency"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_grouped_bottom"
                    android:paddingHorizontal="16dp"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/settings_label_update_frequency"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp"
                        android:fontFamily="@font/geologica_regular"
            app:fontFamily="@font/geologica_regular" />

                    <TextView
                        android:id="@+id/tv_update_frequency_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/update_freq_daily"
                        android:textColor="@color/accent"
                        android:tag="accent_text"
                        android:textSize="16sp"
                        android:fontFamily="@font/geologica_medium"
            app:fontFamily="@font/geologica_medium" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/settings_desc_update_check"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:fontFamily="@font/geologica_regular"
            app:fontFamily="@font/geologica_regular"
            android:layout_marginBottom="24dp"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp"
            android:alpha="0.8" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
